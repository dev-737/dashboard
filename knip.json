{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/scripts/**/*.ts",
    "src/app/**/{page,layout,loading,error,not-found,global-error,route,template,default}.{ts,tsx}"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts", "src/lib/generated/**/*"],
  "ignoreDependencies": []
}
